{
  "manifest_version": 3,
  "name": "Football Match Predictor",
  "version": "1.0.0",
  "description": "AI-powered football match outcome predictions powered by lightweight ML models",
  
  "permissions": [
    "scripting",
    "storage",
    "tabs"
  ],
  
  "host_permissions": [
    "<all_urls>"
  ],
  
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  
  "content_scripts": [],
  
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Football Predictor",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  
  "web_accessible_resources": [
    {
      "resources": ["src/models/football-model.onnx"],
      "matches": ["<all_urls>"]
    }
  ],
  
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}
